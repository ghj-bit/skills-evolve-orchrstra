# Copy this file to .env and edit values for your machine.

# OpenAI-compatible endpoint for the local Uno policy/router checkpoint.
# Example server:
#   python -m vllm.entrypoints.openai.api_server \
#     --host 0.0.0.0 --port 8000 --model Qwen/Qwen2.5-7B-Instruct
LOCAL_BASE=http://localhost:8000/v1
LOCAL_MODEL=Qwen/Qwen2.5-7B-Instruct

# OpenAI-compatible endpoint for the worker model pool in configs/pools.yaml.
# This can be LiteLLM, vLLM, an internal gateway, or any server exposing
# /v1/models and /v1/chat/completions.
API_BASE=http://localhost:9000/v1
API_KEY=EMPTY

# Optional LiteLLM gateway variables used by configs/litellm.example.yaml.
# LITELLM_MASTER_KEY=local-worker-gateway-key
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GEMINI_API_KEY=
# KIMI_API_KEY=
# KIMI_API_BASE=
# GEMINI_FLASH_LITE_MODEL=gemini/gemini-2.5-flash-lite
# GEMINI_FLASH_MODEL=gemini/gemini-2.5-flash
# GEMINI_3_FLASH_MODEL=gemini/gemini-3-flash-preview
# KIMI_MODEL=openai/kimi-k2.5
# CODEX_WORKER_MODEL=openai/gpt-5.3-codex
# GPT_WORKER_MODEL=openai/gpt-5.4
# CLAUDE_SONNET_MODEL=anthropic/claude-sonnet-4-6
# CLAUDE_OPUS_MODEL=anthropic/claude-opus-4-6

# Evaluation defaults.
EVAL_OUT=data/eval
PASS_K=2
GEN_WORKERS=8
VERIFY_WORKERS=4

# Uno schema prompt. Leave unset to use configs/uno/system_prompt.txt.
# UNO_SYSTEM_PROMPT=/absolute/path/to/system_prompt.txt

# Hugging Face cache location. Optional, but recommended for shared machines.
# HF_HOME=/path/to/hf-cache
# HF_DATASETS_CACHE=/path/to/hf-cache/datasets

# Terminal-Bench task cache. The evaluator expects package directories with
# task.toml/instruction.md/tests/environment.
# Install/download Terminal-Bench tasks separately, then point this variable at
# the package root. The code default is data/terminal-bench/tasks.
TERMINAL_BENCH_TASKS_DIR=data/terminal-bench/tasks

# Optional proxy injection for Terminal-Bench Docker containers. Disabled by
# default. Set these only if your task containers need outbound network.
# TBENCH_HTTP_PROXY=http://host.docker.internal:7890
# TBENCH_HTTPS_PROXY=http://host.docker.internal:7890
# TBENCH_ALL_PROXY=socks5://host.docker.internal:7890
# TBENCH_NO_PROXY=localhost,127.0.0.1

# SWE-bench uses official swebench/sweb.eval.* Docker images. Ensure Docker can
# pull from the registry, or pre-pull images before evaluation.
